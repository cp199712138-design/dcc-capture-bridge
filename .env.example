# Copy this file to .env locally if you want to document settings.
# Never commit real keys.

# Optional: enables real API image editing in the local server.
OPENAI_API_KEY=

# Optional image model override.
OPENAI_IMAGE_MODEL=gpt-image-1.5

# Optional local-only lock for future shared demos.
# Leave empty for personal localhost testing.
DCC_CAPTURE_LOCAL_TOKEN=
