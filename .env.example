# Copy this file to .env or set the variables in your shell.
# Never commit a real API key.

OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_IMAGE_MODEL=gpt-image-1

# Optional customer-owned image API adapter.
# The local server sends JSON with prompt, sourceImageDataUrl, maskDataUrl,
# assets, mask, output, reason, strength, and dcc_capture_bridge.contract.
# output contains prompt_mode, aspect_ratio, seed, target, mode, and type.
DCC_CUSTOM_API_URL=
DCC_CUSTOM_API_KEY=
DCC_CUSTOM_API_MODEL=
DCC_CUSTOM_API_AUTH_HEADER=authorization
DCC_CUSTOM_API_AUTH_SCHEME=Bearer
DCC_CUSTOM_API_METHOD=POST
DCC_CUSTOM_API_HEADERS={}
